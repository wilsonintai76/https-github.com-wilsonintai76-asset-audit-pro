{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a system user (Admin, Coordinator, Auditor, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "roles": { "type": "array", "items": { "type": "string", "enum": ["Admin", "Coordinator", "Supervisor", "Staff"] } },
        "departmentId": { "type": "string", "description": "Reference to Department ID" },
        "certificationExpiry": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Suspended"] }
      },
      "required": ["id", "name", "email", "roles", "status"]
    },
    "Department": {
      "title": "Department",
      "description": "Organizational unit (e.g., JKE, JKA)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "abbr": { "type": "string" },
        "headOfDeptId": { "type": "string" },
        "auditGroup": { "type": "string" }
      },
      "required": ["id", "name", "abbr"]
    },
    "Location": {
      "title": "Location",
      "description": "Physical location to be audited",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "departmentId": { "type": "string" },
        "building": { "type": "string", "description": "Block or Building name" },
        "level": { "type": "string", "description": "Floor level" },
        "supervisorId": { "type": "string" }
      },
      "required": ["id", "name", "departmentId", "building"]
    },
    "AuditSchedule": {
      "title": "Audit Schedule",
      "description": "A scheduled audit instance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "departmentId": { "type": "string" },
        "locationId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed"] },
        "phaseId": { "type": "string" },
        "auditor1Id": { "type": "string" },
        "auditor2Id": { "type": "string" }
      },
      "required": ["id", "departmentId", "locationId", "status", "phaseId"]
    },
    "AuditPhase": {
      "title": "Audit Phase",
      "description": "Time-bound audit period (e.g., Q1 2026)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" }
      },
      "required": ["id", "name", "startDate", "endDate"]
    },
    "CrossAuditPermission": {
      "title": "Cross Audit Permission",
      "description": "Rules defining which departments can audit others",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "auditorDeptId": { "type": "string" },
        "targetDeptId": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "auditorDeptId", "targetDeptId", "isActive"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of system users"
    },
    "departments": {
      "schema": "Department",
      "description": "Organizational departments"
    },
    "locations": {
      "schema": "Location",
      "description": "Physical locations for audits"
    },
    "audit_schedules": {
      "schema": "AuditSchedule",
      "description": "Master schedule of all audits"
    },
    "audit_phases": {
      "schema": "AuditPhase",
      "description": "Configuration for audit timeframes"
    },
    "cross_audit_permissions": {
      "schema": "CrossAuditPermission",
      "description": "Matrix of allowed cross-department audits"
    }
  }
}
